# ============================================
# AutoFollowUp AI — Environment Variables
# Copy to .env.local and fill in your values
# ============================================

# --- Supabase (REQUIRED) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI / LLM (REQUIRED) ---
GROQ_API_KEY=gsk_your-groq-api-key

# --- Meta / Facebook (REQUIRED for automation) ---
META_APP_ID=2764382733907632
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=autofollowup_verify_token_2024

# Legacy single-page token (optional if using multi-page OAuth)
# META_PAGE_TOKEN=your-page-access-token
# META_PAGE_ID=your-page-id
# META_PAGE_TOKENS={"page_id":"token"} (JSON map for multi-page)

# --- Cron / Webhooks (REQUIRED) ---
CRON_SECRET=your-random-cron-secret

# --- Stripe Billing (REQUIRED for paid plans) ---
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_UNLIMITED=price_xxx

# --- App URL (REQUIRED for OAuth redirects + billing) ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Optional ---
# SERVICEM8_API_KEY=your-servicem8-key
# META_SKIP_SIGNATURE_CHECK=false
# WEBHOOK_INLINE_COMMENTS=false
# WEBHOOK_QUEUE_MESSAGES=false
# FEED_STALE_WARN_HOURS=6
